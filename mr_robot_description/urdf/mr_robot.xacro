<?xml version="1.0" ?>
<robot name="mr_robot" xmlns:xacro="http://www.ros.org/wiki/xacro">

<xacro:include filename="$(find mr_robot_description)/urdf/materials.xacro" />
<xacro:include filename="$(find mr_robot_description)/urdf/mr_robot.trans" />
<xacro:include filename="$(find mr_robot_description)/urdf/mr_robot.gazebo" />
<link name="base_link">
  <inertial>
    <origin rpy="0 0 0" xyz="-0.014450932103391633 0.0033621168304846854 0.04842175836174598"/>
    <mass value="0.8578681198033654"/>
    <inertia ixx="0.007768" ixy="1e-06" ixz="0.000209" iyy="0.007562" iyz="-3e-06" izz="0.014859"/>
  </inertial>
  <visual>
    <origin rpy="0 0 0" xyz="0 0 0"/>
    <geometry>
      <mesh filename="package://mr_robot_description/meshes/base_link.stl" scale="0.001 0.001 0.001"/>
    </geometry>
    <material name="silver"/>
  </visual>
  <collision>
    <origin rpy="0 0 0" xyz="0 0 0"/>
    <geometry>
      <mesh filename="package://mr_robot_description/meshes/base_link.stl" scale="0.001 0.001 0.001"/>
    </geometry>
  </collision>
</link>

<link name="r_wheel_1">
  <inertial>
    <origin rpy="0 0 0" xyz="1.974679100791299e-14 -0.002525912487815571 -1.9068080447937064e-14"/>
    <mass value="0.17056892200116738"/>
    <inertia ixx="0.000171" ixy="-0.0" ixz="-0.0" iyy="0.000291" iyz="0.0" izz="0.000171"/>
  </inertial>
  <visual>
    <origin rpy="0 0 0" xyz="-0.00225 0.0962 -0.0534"/>
    <geometry>
      <mesh filename="package://mr_robot_description/meshes/r_wheel_1.stl" scale="0.001 0.001 0.001"/>
    </geometry>
    <material name="silver"/>
  </visual>
  <collision>
    <origin rpy="0 0 0" xyz="-0.00225 0.0962 -0.0534"/>
    <geometry>
      <mesh filename="package://mr_robot_description/meshes/r_wheel_1.stl" scale="0.001 0.001 0.001"/>
    </geometry>
  </collision>
</link>

<link name="l_wheel_1">
  <inertial>
    <origin rpy="0 0 0" xyz="-1.6607375197263963e-14 0.006133491954579892 -9.936496070395151e-15"/>
    <mass value="0.33673316347081705"/>
    <inertia ixx="0.000211" ixy="-0.0" ixz="0.0" iyy="0.000351" iyz="-0.0" izz="0.000211"/>
  </inertial>
  <visual>
    <origin rpy="0 0 0" xyz="-0.00275 -0.1032 -0.0534"/>
    <geometry>
      <mesh filename="package://mr_robot_description/meshes/l_wheel_1.stl" scale="0.001 0.001 0.001"/>
    </geometry>
    <material name="silver"/>
  </visual>
  <collision>
    <origin rpy="0 0 0" xyz="-0.00275 -0.1032 -0.0534"/>
    <geometry>
      <mesh filename="package://mr_robot_description/meshes/l_wheel_1.stl" scale="0.001 0.001 0.001"/>
    </geometry>
  </collision>
</link>

<link name="front_cover_1">
  <inertial>
    <origin rpy="0 0 0" xyz="-9.965579114090684e-06 -2.680147770384167e-16 0.025"/>
    <mass value="0.5845384389566758"/>
    <inertia ixx="0.004444" ixy="-0.0" ixz="0.0" iyy="0.000123" iyz="0.0" izz="0.004323"/>
  </inertial>
  <visual>
    <origin rpy="0 0 0" xyz="-0.15 -0.0035 -0.04"/>
    <geometry>
      <mesh filename="package://mr_robot_description/meshes/front_cover_1.stl" scale="0.001 0.001 0.001"/>
    </geometry>
    <material name="silver"/>
  </visual>
  <collision>
    <origin rpy="0 0 0" xyz="-0.15 -0.0035 -0.04"/>
    <geometry>
      <mesh filename="package://mr_robot_description/meshes/front_cover_1.stl" scale="0.001 0.001 0.001"/>
    </geometry>
  </collision>
</link>

<link name="cover_1">
  <inertial>
    <origin rpy="0 0 0" xyz="0.14879439113660797 -0.00013907701861733688 0.0024942607758273866"/>
    <mass value="3.0449746602441645"/>
    <inertia ixx="0.021423" ixy="-1e-05" ixz="3e-06" iyy="0.025731" iyz="0.0" izz="0.047142"/>
  </inertial>
  <visual>
    <origin rpy="0 0 0" xyz="0.15 -0.0035 -0.09"/>
    <geometry>
      <mesh filename="package://mr_robot_description/meshes/cover_1.stl" scale="0.001 0.001 0.001"/>
    </geometry>
    <material name="silver"/>
  </visual>
  <collision>
    <origin rpy="0 0 0" xyz="0.15 -0.0035 -0.09"/>
    <geometry>
      <mesh filename="package://mr_robot_description/meshes/cover_1.stl" scale="0.001 0.001 0.001"/>
    </geometry>
  </collision>
</link>

<joint name="right_motor_joint" type="continuous">
  <origin rpy="0 0 0" xyz="0.00225 -0.0962 0.0534"/>
  <parent link="base_link"/>
  <child link="r_wheel_1"/>
  <axis xyz="-0.0 -1.0 0.0"/>
</joint>

<joint name="left_motor_joint" type="continuous">
  <origin rpy="0 0 0" xyz="0.00275 0.1032 0.0534"/>
  <parent link="base_link"/>
  <child link="l_wheel_1"/>
  <axis xyz="0.0 1.0 -0.0"/>
</joint>

<joint name="Rigid45" type="fixed">
  <origin rpy="0 0 0" xyz="0.15 0.0035 0.04"/>
  <parent link="base_link"/>
  <child link="front_cover_1"/>
</joint>

<joint name="Rigid46" type="fixed">
  <origin rpy="0 0 0" xyz="-0.15 0.0035 0.09"/>
  <parent link="base_link"/>
  <child link="cover_1"/>
</joint>

</robot>
